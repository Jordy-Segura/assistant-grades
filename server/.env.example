# Copia este archivo como server/.env y completa tus credenciales de servicio OASIS.
# Estas credenciales NUNCA deben llegar al navegador: solo las usa el BFF.

# Usuario/clave del servicio de interoperabilidad (cabecera SOAP <credentials>).
OASIS_USER=
OASIS_PASS=

# Endpoint base de los servicios .asmx (sin barra final).
OASIS_BASE=http://swoasis.espoch.edu.ec/OASis/OAS_Interop

# Puerto del BFF (el frontend usa VITE_API_BASE_URL para apuntar aquí).
PORT=3001

# Supabase: URL del proyecto y service_role key (solo backend, NUNCA en frontend).
# La key se obtiene de: Project Settings → API → service_role key.
# No incluir el valor real aquí. Configurarlo como variable de entorno del sistema.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Origen permitido para CORS en producción (en desarrollo "*" está bien).
# CORS_ORIGIN=http://localhost:5173
